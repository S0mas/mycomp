# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# ── LLM Backend ────────────────────────────────────────────────────────────────

# Provider: anthropic (default) | openai | fake
# "fake" returns canned responses — useful for offline testing
AICOMPANY_LLM_BACKEND=anthropic

# Model to use. Must be supported by the chosen backend.
# Anthropic: claude-sonnet-4-6, claude-opus-4-7, claude-haiku-4-5-20251001
AICOMPANY_MODEL=claude-sonnet-4-6

# Required when AICOMPANY_LLM_BACKEND=anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Required when AICOMPANY_LLM_BACKEND=openai (or any OpenAI-compatible provider)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1   # or http://localhost:11434/v1 for Ollama

# ── MCP Server ─────────────────────────────────────────────────────────────────

# Required for `run`. JSON array of MCP server objects.
# Start the server with: ./scripts/start_mcp.sh (requires cloudflared in project root)
# Then paste the printed tunnel URL here.
AICOMPANY_MCP_SERVERS=[{"type":"url","url":"https://<tunnel>.trycloudflare.com/mcp","name":"mycomp"}]
